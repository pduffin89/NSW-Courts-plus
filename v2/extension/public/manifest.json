{
  "manifest_version": 3,
  "name": "Argus Delta Courtlens",
  "version": "0.1.0",
  "description": "Sidebar research and document workflow assistant for NSW court lists and NSW Caselaw.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.caselaw.nsw.gov.au/*",
    "https://news.google.com/*",
    "https://abr.business.gov.au/*",
    "https://search.judgments.fedcourt.gov.au/*",
    "https://be-api.argusdelta.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://100.89.36.94/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://onlineregistry.lawlink.nsw.gov.au/content/court-lists*"
      ],
      "js": [
        "courtlist.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.caselaw.nsw.gov.au/decision/*",
        "https://www.caselaw.nsw.gov.au/search*"
      ],
      "js": [
        "caselaw.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Argus Delta Courtlens",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

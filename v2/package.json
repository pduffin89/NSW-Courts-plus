{
  "name": "argus-delta-courtlens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Argus Delta Courtlens Chrome extension for NSW court-list and caselaw research workflows.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit && node scripts/build.mjs",
    "audit:policy": "node scripts/extension_policy_audit.mjs",
    "audit:secrets": "node scripts/secret_audit.mjs",
    "audit:package-determinism": "node scripts/package_determinism.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:live": "node scripts/live_smoke.mjs",
    "smoke:live-extension": "python3 scripts/live_extension_smoke.py",
    "smoke:operator": "python3 scripts/operator_live_smoke.py",
    "package:extension": "npm run audit:delivery",
    "verify": "npm test && npm run build && npm run smoke",
    "audit:delivery": "node scripts/delivery_audit.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "lucide-react": "1.17.0",
    "pdf-lib": "1.17.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.43",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "vitest": "4.1.8"
  }
}

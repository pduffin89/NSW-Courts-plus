{
  "name": "argus-delta-courtlens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Argus Delta Courtlens Chrome extension for NSW court-list and caselaw research workflows.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit && node scripts/build.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:live": "node scripts/live_smoke.mjs",
    "verify": "npm test && npm run build && npm run smoke"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "pdf-lib": "^1.17.1",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/chrome": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "latest",
    "vitest": "latest"
  }
}
